{
  "manifest_version": 3,
  "name": "Headmaster",
  "version": "0.1.0",
  "description": "Send extra request headers to matching URLs — no profiles, every rule independent.",
  "permissions": ["declarativeNetRequestWithHostAccess", "storage"],
  "optional_host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Headmaster"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
