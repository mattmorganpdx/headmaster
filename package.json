{
  "name": "headmaster",
  "version": "0.1.0",
  "description": "Send extra request headers to matching URLs — no profiles, every rule independent.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package": "node scripts/package.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.14.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
